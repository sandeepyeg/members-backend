{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.EntityFrameworkCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "DefaultConnection": "Data Source=EnterpriseMembers.dev.db"
  },
  "Jwt": {
    "Secret": "replace-with-local-development-secret-at-least-32-characters",
    "Issuer": "EnterpriseMembers",
    "Audience": "EnterpriseMembers",
    "ExpiryMinutes": "60"
  },
  "Cors": {
    "AllowedOrigins": ["http://localhost:4200"]
  }
}
